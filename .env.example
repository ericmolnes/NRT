# NextAuth.js - generate with: npx auth secret
AUTH_SECRET=

# Microsoft Entra ID (Azure AD)
# Get these from https://entra.microsoft.com > App registrations
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0

# Admin-tilgang (minst én av disse må settes)
# Kommaseparert liste over admin-emailer
ADMIN_EMAILS=eric@nordicrigtech.com
# Eller: Azure AD group ID for admin-tilgang
ADMIN_GROUP_ID=

# Neon PostgreSQL (get from https://console.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require

# Anthropic API (for AI-parsing av arbeidspakker)
ANTHROPIC_API_KEY=

# PowerOffice Go API
# Hent nøkler fra https://developer.poweroffice.net
POWEROFFICE_APPLICATION_KEY=
POWEROFFICE_CLIENT_KEY=
POWEROFFICE_SUBSCRIPTION_KEY=
POWEROFFICE_ENV=demo

# Recman API (rekruttering/bemanning)
# Opprett API-nøkkel i Recman: System settings > Database > API > Create
RECMAN_API_KEY=
RECMAN_API_URL=https://api.recman.io

# Cron-jobb sikkerhetsnøkkel (generer en tilfeldig streng)
# Sett samme verdi i Vercel Environment Variables
CRON_SECRET=
